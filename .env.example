# ─────────────────────────────────────────────────────────────────────────────
# .env.example  –  Copy this file to .env and fill in your own keys.
# NEVER commit your real .env to GitHub — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Which LLM to use by default: vertex | gemini | openai | claude | groq | grok | local
LLM_PROVIDER=vertex

# ── Google Vertex AI (default — requires service_account2.json) ───────────────
VERTEX_PROJECT=your-gcp-project-id
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-flash

# ── Google Gemini (free tier available at aistudio.google.com) ───────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_API_KEY_2=your-second-gemini-key-for-fallback
GEMINI_MODEL=gemini-2.5-flash

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ── Anthropic Claude ─────────────────────────────────────────────────────────
CLAUDE_API_KEY=your-claude-api-key-here
CLAUDE_MODEL=claude-3-5-haiku-20241022

# ── Groq (fast + free tier at console.groq.com) ──────────────────────────────
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# ── xAI Grok ─────────────────────────────────────────────────────────────────
GROK_API_KEY=your-xai-api-key-here
GROK_MODEL=grok-3-mini

# ── OCR Settings ─────────────────────────────────────────────────────────────
# OCR engine: gcv (Google Cloud Vision, best) | easyocr (free, no key needed)
OCR_ENGINE=gcv
OCR_CONFIDENCE_THRESHOLD=0.3
OCR_WORKERS=4
TILE_SIZE=1024
TILE_OVERLAP=50

# ── Ensemble Mode (optional) ─────────────────────────────────────────────────
# Run ALL configured LLMs in parallel and vote on results (slower but more accurate)
ENSEMBLE_MODE=false
LLM_ENSEMBLE_WORKERS=4
